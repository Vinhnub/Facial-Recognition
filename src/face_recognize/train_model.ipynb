    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "sns.set(style=\"whitegrid\")\n",
    "\n",
    "# =============================\n",
    "# LOAD RESULTS\n",
    "# =============================\n",
    "\n",
    "df = pd.read_csv(\"models/train_results.csv\")\n",
    "\n",
    "print(df.head())\n",
    "\n",
    "\n",
    "# =============================\n",
    "# 1️⃣ KERNEL COMPARISON\n",
    "# =============================\n",
    "\n",
    "plt.figure(figsize=(10,6))\n",
    "\n",
    "sns.barplot(\n",
    "    data=df,\n",
    "    x=\"Kernel\",\n",
    "    y=\"Test Accuracy\",\n",
    "    hue=\"Method\"\n",
    ")\n",
    "\n",
    "plt.title(\"SVM Kernel Comparison\")\n",
    "plt.ylabel(\"Test Accuracy\")\n",
    "plt.xlabel(\"Kernel\")\n",
    "plt.ylim(0.7,1)\n",
    "\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# =============================\n",
    "# 2️⃣ METHOD COMPARISON\n",
    "# =============================\n",
    "\n",
    "plt.figure(figsize=(10,6))\n",
    "\n",
    "sns.barplot(\n",
    "    data=df,\n",
    "    x=\"Method\",\n",
    "    y=\"Test Accuracy\",\n",
    "    hue=\"Kernel\"\n",
    ")\n",
    "\n",
    "plt.title(\"Multi-class Strategy Comparison\")\n",
    "plt.ylabel(\"Test Accuracy\")\n",
    "\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# =============================\n",
    "# 3️⃣ MODEL STABILITY (BOXPLOT)\n",
    "# =============================\n",
    "\n",
    "plt.figure(figsize=(10,6))\n",
    "\n",
    "sns.boxplot(\n",
    "    data=df,\n",
    "    x=\"Kernel\",\n",
    "    y=\"Test Accuracy\",\n",
    "    hue=\"Method\"\n",
    ")\n",
    "\n",
    "plt.title(\"Model Stability Across Runs\")\n",
    "\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# =============================\n",
    "# 4️⃣ CV vs TEST (OVERFITTING CHECK)\n",
    "# =============================\n",
    "\n",
    "plt.figure(figsize=(8,6))\n",
    "\n",
    "sns.scatterplot(\n",
    "    data=df,\n",
    "    x=\"CV Accuracy\",\n",
    "    y=\"Test Accuracy\",\n",
    "    hue=\"Method\",\n",
    "    style=\"Kernel\",\n",
    "    s=120\n",
    ")\n",
    "\n",
    "plt.plot([0.7,1],[0.7,1],'r--')\n",
    "\n",
    "plt.title(\"Cross Validation vs Test Accuracy\")\n",
    "\n",
    "plt.xlabel(\"CV Accuracy\")\n",
    "plt.ylabel(\"Test Accuracy\")\n",
    "\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# =============================\n",
    "# 5️⃣ PERFORMANCE HEATMAP\n",
    "# =============================\n",
    "\n",
    "pivot = df.pivot_table(\n",
    "    values=\"Test Accuracy\",\n",
    "    index=\"Method\",\n",
    "    columns=\"Kernel\",\n",
    "    aggfunc=\"mean\"\n",
    ")\n",
    "\n",
    "plt.figure(figsize=(8,5))\n",
    "\n",
    "sns.heatmap(\n",
    "    pivot,\n",
    "    annot=True,\n",
    "    cmap=\"YlGnBu\",\n",
    "    fmt=\".3f\"\n",
    ")\n",
    "\n",
    "plt.title(\"Average Test Accuracy Heatmap\")\n",
    "\n",
    "plt.show()"
   ]
